{
 "doctype": "DocType",
 "name": "Maintenance Request",
 "module": "Maintenance",
 "custom": 0,
 "istable": 0,
 "engine": "InnoDB",
 "autoname": "hash",
 "track_changes": 1,
 "fields": [
  {
   "fieldname": "room",
   "label": "Room",
   "fieldtype": "Link",
   "options": "Room",
   "in_list_view": 1
  },
  {
   "fieldname": "issue",
   "label": "Issue",
   "fieldtype": "Small Text",
   "reqd": 1
  },
  {
   "fieldname": "status",
   "label": "Status",
   "fieldtype": "Select",
   "options": "open\nassigned\nin_progress\nresolved\nclosed",
   "reqd": 1,
   "default": "open",
   "in_list_view": 1
  },
  {
   "fieldname": "priority",
   "label": "Priority",
   "fieldtype": "Select",
   "options": "low\nmedium\nhigh\nurgent",
   "default": "medium"
  },
  {
   "fieldname": "technician",
   "label": "Technician",
   "fieldtype": "Link",
   "options": "User",
   "in_list_view": 1
  },
  {
   "fieldname": "opened_at",
   "label": "Opened At",
   "fieldtype": "Datetime",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "closed_at",
   "label": "Closed At",
   "fieldtype": "Datetime"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "report": 1,
   "export": 1,
   "print": 1,
   "email": 1,
   "share": 1
  },
  {
   "role": "Housekeeping Staff",
   "read": 1,
   "write": 1,
   "create": 1,
   "report": 1,
   "export": 1,
   "print": 1,
   "email": 1,
   "share": 1
  }
 ]
}
