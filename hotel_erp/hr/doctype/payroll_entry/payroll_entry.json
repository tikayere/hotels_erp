{
 "doctype": "DocType",
 "icon": "fa fa-money",
 "name": "Payroll Entry",
 "module": "HR",
 "custom": 0,
 "istable": 0,
 "engine": "InnoDB",
 "autoname": "hash",
 "track_changes": 1,
 "fields": [
  {
   "fieldname": "staff",
   "label": "Staff",
   "fieldtype": "Link",
   "options": "Staff",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "pay_period_start",
   "label": "Pay Period Start",
   "fieldtype": "Date",
   "reqd": 1
  },
  {
   "fieldname": "pay_period_end",
   "label": "Pay Period End",
   "fieldtype": "Date",
   "reqd": 1
  },
  {
   "fieldname": "gross_amount_minor",
   "label": "Gross Amount (minor units)",
   "fieldtype": "Int",
   "reqd": 1
  },
  {
   "fieldname": "deductions_minor",
   "label": "Deductions (minor units)",
   "fieldtype": "Int",
   "default": "0"
  },
  {
   "fieldname": "net_amount_minor",
   "label": "Net Amount (minor units)",
   "fieldtype": "Int",
   "reqd": 1
  },
  {
   "fieldname": "currency",
   "label": "Currency",
   "fieldtype": "Data",
   "reqd": 1,
   "length": 3
  },
  {
   "fieldname": "status",
   "label": "Status",
   "fieldtype": "Select",
   "options": "draft\nprocessed\npaid",
   "default": "draft",
   "in_list_view": 1
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "report": 1,
   "export": 1,
   "print": 1,
   "email": 1,
   "share": 1
  }
 ]
}
