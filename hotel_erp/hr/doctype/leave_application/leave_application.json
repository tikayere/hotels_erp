{
 "doctype": "DocType",
 "name": "Leave Application",
 "module": "HR",
 "custom": 0,
 "istable": 0,
 "engine": "InnoDB",
 "autoname": "hash",
 "track_changes": 1,
 "fields": [
  {
   "fieldname": "staff",
   "label": "Staff",
   "fieldtype": "Link",
   "options": "Staff",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "leave_type",
   "label": "Leave Type",
   "fieldtype": "Select",
   "options": "annual\nsick\nunpaid\nmaternity_paternity",
   "reqd": 1
  },
  {
   "fieldname": "from_date",
   "label": "From Date",
   "fieldtype": "Date",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "to_date",
   "label": "To Date",
   "fieldtype": "Date",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "status",
   "label": "Status",
   "fieldtype": "Select",
   "options": "pending\napproved\nrejected",
   "default": "pending",
   "in_list_view": 1
  },
  {
   "fieldname": "reason",
   "label": "Reason",
   "fieldtype": "Small Text"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "report": 1,
   "export": 1,
   "print": 1,
   "email": 1,
   "share": 1
  }
 ]
}
