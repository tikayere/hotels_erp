{
 "doctype": "DocType",
 "icon": "fa fa-bed",
 "name": "Room Type",
 "module": "Room",
 "custom": 0,
 "istable": 0,
 "engine": "InnoDB",
 "autoname": "hash",
 "track_changes": 1,
 "image_field": "cover_image",
 "fields": [
  {
   "fieldname": "property",
   "label": "Property",
   "fieldtype": "Link",
   "options": "Property",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "code",
   "label": "Code",
   "fieldtype": "Data",
   "reqd": 1,
   "in_list_view": 1,
   "description": "Bare room_type_id before namespacing; unique per property"
  },
  {
   "fieldname": "room_type_name",
   "label": "Room Type Name",
   "fieldtype": "Data",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "description",
   "label": "Description",
   "fieldtype": "Text Editor"
  },
  {
   "fieldname": "max_occupancy_adults",
   "label": "Max Occupancy Adults",
   "fieldtype": "Int",
   "reqd": 1
  },
  {
   "fieldname": "max_occupancy_children",
   "label": "Max Occupancy Children",
   "fieldtype": "Int",
   "default": "0"
  },
  {
   "fieldname": "bed_config",
   "label": "Bed Configuration",
   "fieldtype": "Data"
  },
  {
   "fieldname": "size_sqm",
   "label": "Size (sqm)",
   "fieldtype": "Float"
  },
  {
   "fieldname": "amenity_list",
   "label": "Amenities",
   "fieldtype": "Table",
   "options": "Room Type Amenity"
  },
  {
   "fieldname": "amenities",
   "label": "Amenities (raw)",
   "fieldtype": "JSON",
   "read_only": 1,
   "hidden": 1,
   "description": "Auto-generated from the Amenities table above -- do not edit directly."
  },
  {
   "fieldname": "photo_gallery",
   "label": "Photos",
   "fieldtype": "Table",
   "options": "Room Type Photo",
   "description": "Drag to reorder -- the first photo is used as the cover image on the Portal/Web listing."
  },
  {
   "fieldname": "photos",
   "label": "Photos (URLs)",
   "fieldtype": "JSON",
   "read_only": 1,
   "hidden": 1,
   "description": "Auto-generated from the Photos gallery above -- do not edit directly."
  },
  {
   "fieldname": "cover_image",
   "label": "Cover Image",
   "fieldtype": "Attach Image",
   "read_only": 1,
   "hidden": 1,
   "description": "Auto-set to the first photo above -- shown as the thumbnail in list/report views."
  },
  {
   "fieldname": "active",
   "label": "Active",
   "fieldtype": "Check",
   "default": "1"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "report": 1,
   "export": 1,
   "print": 1,
   "email": 1,
   "share": 1
  },
  {
   "role": "Revenue Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "report": 1,
   "export": 1,
   "print": 1,
   "email": 1,
   "share": 1
  },
  {
   "role": "Hotel API",
   "read": 1,
   "report": 1,
   "export": 1,
   "print": 1
  }
 ]
}
