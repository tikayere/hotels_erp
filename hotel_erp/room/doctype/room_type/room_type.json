  {"fieldname": "max_occupancy_children", "label": "Max Occupancy Children", "fieldtype": "Int", "default": "0"},
  {"fieldname": "bed_config", "label": "Bed Configuration", "fieldtype": "Data"},
  {"fieldname": "size_sqm", "label": "Size (sqm)", "fieldtype": "Float"},
  {"fieldname": "amenities", "label": "Amenities", "fieldtype": "JSON", "description": "Array of strings"},
  {"fieldname": "photos", "label": "Photos", "fieldtype": "JSON", "description": "Array of URLs"},
  {"fieldname": "active", "label": "Active", "fieldtype": "Check", "default": "1"}
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
  {"role": "Revenue Manager", "read": 1, "write": 1, "create": 1},
  {"role": "Hotel API", "read": 1}
 ]
}
