 "fields": [
  {"fieldname": "property", "label": "Property", "fieldtype": "Link", "options": "Property", "reqd": 1, "in_list_view": 1},
  {"fieldname": "code", "label": "Code", "fieldtype": "Data", "reqd": 1, "in_list_view": 1, "description": "Bare room_type_id before namespacing; unique per property"},
  {"fieldname": "room_type_name", "label": "Room Type Name", "fieldtype": "Data", "reqd": 1, "in_list_view": 1},
  {"fieldname": "description", "label": "Description", "fieldtype": "Text Editor"},
