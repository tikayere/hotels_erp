{
 "doctype": "DocType",
 "name": "Inventory Item",
 "module": "Inventory",
 "custom": 0,
 "istable": 0,
 "engine": "InnoDB",
 "autoname": "hash",
 "track_changes": 1,
 "fields": [
  {
   "fieldname": "item_name",
   "label": "Item Name",
   "fieldtype": "Data",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "category",
   "label": "Category",
   "fieldtype": "Select",
   "options": "linen\ncleaning_supplies\nfood\nmaintenance_supplies",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "unit",
   "label": "Unit",
   "fieldtype": "Data",
   "description": "e.g. pcs, kg, box"
  },
  {
   "fieldname": "quantity_on_hand",
   "label": "Quantity On Hand",
   "fieldtype": "Float",
   "default": "0",
   "in_list_view": 1
  },
  {
   "fieldname": "reorder_level",
   "label": "Reorder Level",
   "fieldtype": "Float",
   "default": "0"
  },
  {
   "fieldname": "preferred_supplier",
   "label": "Preferred Supplier",
   "fieldtype": "Link",
   "options": "Supplier"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "report": 1,
   "export": 1,
   "print": 1,
   "email": 1,
   "share": 1
  },
  {
   "role": "Housekeeping Staff",
   "read": 1,
   "report": 1,
   "export": 1,
   "print": 1
  }
 ]
}
